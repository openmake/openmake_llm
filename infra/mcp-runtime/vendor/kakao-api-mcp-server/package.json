{
  "name": "kakao-api-mcp-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "kakao-api-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "start": "npm run build && node dist/index.js --mode=http --port=3000",
    "start:stdio": "npm run build && node dist/index.js --mode=stdio",
    "dev": "npm run build && node dist/index.js --mode=http --port=3000"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Kakao Local(Map) + Daum Search MCP server (stdio/http)",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.32",
    "typescript": "^5.4.5"
  }
}
