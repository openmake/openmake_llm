      "build:frontend": "cd frontend/web && npm run build",
      "deploy:frontend": "bash scripts/deploy-frontend.sh",
      "build:all": "npm run build",
      "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
      "dev:api": "cd backend/api && npm run dev",
      "dev:frontend": "cd frontend/web && npm run dev",
      "start": "node backend/api/dist/server.js",
      "start:api": "node backend/api/dist/server.js",
      "test": "jest",
      "test:unit": "cd tests/unit && jest",
      "test:integration": "cd tests/integration && jest",
      "test:e2e": "npx playwright test",
      "test:e2e:ui": "npx playwright test --ui",
      "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
      "clean": "rm -rf */dist **/dist",
      "check:schema-drift": "bash scripts/check-schema-drift.sh",
      "ci": "bash scripts/ci-test.sh",
      "hooks:install": "bash scripts/install-hooks.sh",
      "test:bun": "cd backend/api && bun test --timeout 15000",
      "migrate": "npx ts-node scripts/run-migrations.ts"
    }
