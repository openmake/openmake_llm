{
    "name": "openmake-api",
    "version": "1.5.6",
    "description": "OpenMake API Server",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc && npm run copy-agent-data && npm run build-info",
        "copy-agent-data": "cp -r src/agents/data dist/agents/data",
        "build-info": "node -e \"const{execSync}=require('child_process');const fs=require('fs');const i={buildTime:new Date().toISOString(),gitHash:execSync('git rev-parse --short HEAD').toString().trim(),gitDate:execSync('git log -1 --format=%cd --date=short').toString().trim()};fs.writeFileSync('dist/build-info.json',JSON.stringify(i));console.log('build-info:',i);\"",
        "dev": "ts-node --files src/server.ts",
        "start": "node dist/server.js",
        "watch": "tsc --watch",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "eval:routing": "ts-node src/evaluation/run-evaluation.ts",
        "eval:routing:strict": "OMK_EVAL_PASS_THRESHOLD=1.0 ts-node src/evaluation/run-evaluation.ts",
        "eval:augmented": "ts-node src/evaluation/run-augmented-evaluation.ts",
        "eval:response": "ts-node src/evaluation/run-response-evaluation.ts",
        "eval:citation": "ts-node src/evaluation/run-citation-evaluation.ts",
        "eval:all": "npm run eval:routing && npm run eval:response && npm run eval:citation"
    },
    "dependencies": {
        "@openmake/shared-types": "1.5.6",
        "@anthropic-ai/sdk": "^0.95.1",
        "@modelcontextprotocol/sdk": "^1.25.3",
        "@mozilla/readability": "^0.6.0",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
        "@opentelemetry/instrumentation-express": "^0.67.0",
        "@opentelemetry/instrumentation-http": "^0.219.0",
        "@opentelemetry/resources": "^2.8.0",
        "@opentelemetry/sdk-node": "^0.219.0",
        "@opentelemetry/sdk-trace-node": "^2.8.0",
        "@opentelemetry/semantic-conventions": "^1.41.1",
        "@types/pg": "^8.16.0",
        "axios": "^1.13.2",
        "babel-jest": "^30.4.1",
        "bcryptjs": "^3.0.3",
        "chalk": "^4.1.2",
        "cli-highlight": "^2.1.11",
        "commander": "^14.0.3",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "inquirer": "^13.2.2",
        "ioredis": "^5.10.1",
        "js-yaml": "^4.1.1",
        "jsdom": "^29.0.1",
        "jsonwebtoken": "^9.0.3",
        "lru-cache": "^7.18.3",
        "multer": "^2.0.2",
        "nodemailer": "^9.0.0",
        "openai": "^6.37.0",
        "ora": "^9.2.0",
        "pg": "^8.18.0",
        "turndown": "^7.2.2",
        "turndown-plugin-gfm": "^1.0.2",
        "undici": "^7.24.5",
        "uuid": "^13.0.0",
        "web-push": "^3.6.7",
        "winston": "^3.19.0",
        "ws": "^8.18.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.7",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.6",
        "@types/inquirer": "^9.0.9",
        "@types/jest": "^30.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/jsdom": "^28.0.1",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^24.0.0",
        "@types/turndown": "^5.0.6",
        "@types/web-push": "^3.6.4",
        "@types/ws": "^8.18.1",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.2"
    }
}
