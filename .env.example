# ============================================================
# OpenMake 통합 환경 설정 (Template)
# ============================================================
# 이 파일은 환경 변수 설정 템플릿입니다.
# .env 파일을 생성할 때 이 파일을 참고하여 실제 값을 입력하세요.
#
# 빠른 시작:
#   cp .env.example .env
#   # .env 파일을 열어 실제 값을 입력하세요

# *******************************************************
# 🤖 OLLAMA & LLM 설정
# *******************************************************
# Ollama 접속 정보 (OLLAMA_BASE_URL 사용, OLLAMA_HOST는 미사용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=gemini-3-flash-preview:cloud
OLLAMA_TIMEOUT=120000

# OLLAMA Cloud API Keys (다중 키 순환 로테이션 지원)
# 각 키는 Ollama Cloud에서 발급받은 API 키를 입력하세요
OLLAMA_API_KEY_1=your_ollama_api_key_1_here
OLLAMA_API_KEY_2=your_ollama_api_key_2_here
OLLAMA_API_KEY_3=your_ollama_api_key_3_here
OLLAMA_API_KEY_4=your_ollama_api_key_4_here
OLLAMA_API_KEY_5=your_ollama_api_key_5_here

# 각 API 키별 모델 설정 (A2A 병렬 모델 지원, 선택 사항)
OLLAMA_MODEL_1=gemini-3-flash-preview:cloud
OLLAMA_MODEL_2=gpt-oss:120b-cloud
OLLAMA_MODEL_3=kimi-k2.5:cloud
OLLAMA_MODEL_4=qwen3-coder-next:cloud
OLLAMA_MODEL_5=qwen3-vl:235b-cloud

# 레거시 호환성 및 폴백 키
OLLAMA_API_KEY_PRIMARY=your_ollama_api_key_primary_here
OLLAMA_API_KEY_SECONDARY=your_ollama_api_key_secondary_here

# API 사용량 제한 (Quota)
OLLAMA_HOURLY_LIMIT=150
OLLAMA_WEEKLY_LIMIT=2500
OLLAMA_MONTHLY_PREMIUM_LIMIT=5

# *******************************************************
# 🌌 GEMINI 전용 상세 설정
# *******************************************************
# 참고: Gemini 모델은 OLLAMA_API_KEY 풀로 접근 (별도 API Key 불필요)
GEMINI_THINK_ENABLED=true
GEMINI_THINK_LEVEL=high
GEMINI_NUM_CTX=32768
GEMINI_WEB_SEARCH_ENABLED=true

# *******************************************************
# 🔐 서버 및 보안 설정
# *******************************************************
PORT=52416
SERVER_HOST=localhost
NODE_ENV=development

# 인증 보안 키 (필수! 생성: openssl rand -hex 32)
JWT_SECRET=generate_with_openssl_rand_-hex_32
API_KEY_PEPPER=generate_with_openssl_rand_-hex_32
ADMIN_PASSWORD=your_secure_admin_password_here

# OAuth 토큰 암호화 키 (P0 보안 - 프로덕션 필수!)
# external_connections 테이블의 access_token/refresh_token을 AES-256-GCM으로 암호화합니다.
# 반드시 64자리 hex 문자열(32 bytes)이어야 합니다.
# 생성 방법: openssl rand -hex 32
# 미설정 시: 토큰이 평문으로 저장됩니다 (개발환경 허용, 프로덕션 금지)
# 경고: 키를 변경하면 기존 암호화된 토큰을 복호화할 수 없습니다. 키는 안전하게 보관하세요.
TOKEN_ENCRYPTION_KEY=

# 관리자 권한 설정
ADMIN_EMAILS=admin@example.com
DEFAULT_ADMIN_EMAIL=admin@example.com

# *******************************************************
# 🔑 GOOGLE OAUTH 2.0 (소셜 로그인)
# *******************************************************
# Google Cloud Console에서 OAuth 2.0 자격증명 생성
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:52416/api/auth/callback/google

# *******************************************************
# 🔍 웹 검색 설정 (Google Custom Search)
# *******************************************************
# Google API 키 (Google Custom Search 활성화 필요)
GOOGLE_API_KEY=your_google_api_key_here
# Google Custom Search Engine ID
GOOGLE_CSE_ID=your_google_cse_id_here

# *******************************************************
# 📊 인프라 및 네트워크 설정
# *******************************************************
# PostgreSQL 데이터베이스 (필수)
DATABASE_URL=postgresql://openmake:your_password@localhost:5432/openmake_llm

# 캐시 설정
CACHE_MAX_SIZE=1000
CACHE_TTL=1800000

# Ollama 클러스터 기본 노드 설정
OLLAMA_DEFAULT_HOST=localhost
OLLAMA_DEFAULT_PORT=11434
OLLAMA_DEFAULT_NODE_NAME=primary

# CORS 및 API 문서 (프로덕션에서는 실제 도메인으로 변경)
CORS_ORIGINS=http://localhost:52416,http://localhost:5173,http://localhost:3000
SWAGGER_BASE_URL=http://localhost:52416
LOG_LEVEL=info

# Rate Limiting (900초당 100회 제한)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# *******************************************************
# P2: 비용 티어 & 도메인 라우팅
# *******************************************************
# 비용 티어 기본값 (economy/standard/premium)
# premium = 제한 없음 (기본값), economy = 최저 비용
OMK_COST_TIER_DEFAULT=premium

# 도메인별 전문 모델 (빈 값 = 프로파일 기본 엔진 사용)
# auto-routing(openmake_llm_auto) 시에만 적용
# OMK_DOMAIN_CODE=glm-5:cloud
# OMK_DOMAIN_MATH=gpt-oss:120b-cloud
# OMK_DOMAIN_CREATIVE=kimi-k2.5:cloud
# OMK_DOMAIN_ANALYSIS=kimi-k2.5:cloud
# OMK_DOMAIN_GENERAL=gemini-3-flash-preview:cloud

# Cookie Security (HTTPS 없이 운영 시 false, HTTPS 환경에서는 true 권장)
COOKIE_SECURE=false

# *******************************************************
# 🔥 FIRECRAWL (웹 스크래핑/크롤링)
# *******************************************************
# Firecrawl API 키 (https://firecrawl.dev 에서 발급)
# 설정 시 firecrawl_scrape, firecrawl_search, firecrawl_map, firecrawl_crawl MCP 도구 활성화
# 미설정 시 Firecrawl 도구가 자동으로 비활성화됩니다
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# Firecrawl API URL (기본값: https://api.firecrawl.dev/v1, 셀프호스팅 시 변경)
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v1
# *******************************************************
# 🌐 다국어 응답 정책 (Language Policy)
# *******************************************************
# 동적 언어 감지 활성화 (false=기본 언어로 고정, true=사용자 언어 자동 감지)
ENABLE_DYNAMIC_RESPONSE_LANGUAGE=false
# 기본 응답 언어 (ko, en, ja, zh, es, fr, de 등 20개 지원)
DEFAULT_RESPONSE_LANGUAGE=ko
# 언어 감지 최소 신뢰도 (0.0~1.0, 미만 시 fallback 언어 사용)
LANGUAGE_DETECTION_MIN_CONFIDENCE=0.7
# 감지 실패 시 폴백 언어
LANGUAGE_FALLBACK_LANGUAGE=en

# *******************************************************
# LLM 라우팅 설정 (선택적, 기본값 사용 권장)
# *******************************************************
# 쿼리 분류 모델 (기본값: gemini-3-flash-preview:cloud)
# OMK_CLASSIFIER_MODEL=gemini-3-flash-preview:cloud

# LLM 분류 최소 신뢰도 임계값 (기본값: 0.7, 이 값 미만이면 regex fallback)
# OMK_CONFIDENCE_THRESHOLD=0.7

# LLM 분류기 temperature - 낮을수록 결정적 응답 (기본값: 0.1)
# OMK_CLASSIFIER_TEMPERATURE=0.1

# LLM 분류기 컨텍스트 토큰 수 (기본값: 1024)
# OMK_CLASSIFIER_NUM_CTX=1024

# LLM 라우터 temperature - 낮을수록 결정적 응답 (기본값: 0.1)
# OMK_ROUTER_TEMPERATURE=0.1

# LLM 라우터 최대 예측 토큰 수 (기본값: 200)
# OMK_ROUTER_NUM_PREDICT=200

# A2A 건너뛰기 임계값 - 이 점수 미만이면 A2A 단계 생략 (기본값: 0.3)
# OMK_A2A_SKIP_THRESHOLD=0.3

# 카테고리 직접 매칭 부스트 점수 (기본값: 3)
# OMK_CATEGORY_BOOST=3

# 확장 키워드 감쇠 계수 (기본값: 0.3)
# OMK_EXPANDED_DAMPING=0.3

# *******************************************************
# UIR (Unified Intent Router) 설정
# *******************************************************
# UIR 전용 모델 (기본값: gemini-3-flash-preview:cloud)
# OMK_UIR_MODEL=gemini-3-flash-preview:cloud

# UIR 롤아웃 비율 (0=shadow only, 100=full UIR, 기본값: 0)
# 점진적 배포 시 10 -> 50 -> 100 순으로 올릴 것
# OMK_UIR_ROLLOUT_PERCENT=0

# UIR shadow 비교 모드 활성화 - UIR과 기존 파이프라인 결과 동시 실행 후 비교 (기본값: false)
# OMK_UIR_SHADOW_ENABLED=false

# UIR 타임아웃 (ms, 기본값: 8000)
# OMK_UIR_TIMEOUT_MS=8000

# UIR temperature - 낮을수록 결정적 응답 (기본값: 0.1)
# OMK_UIR_TEMPERATURE=0.1

# UIR 최대 예측 토큰 수 (기본값: 400)
# OMK_UIR_NUM_PREDICT=400

# UIR pre-filter 최대 에이전트 수 (기본값: 20)
# OMK_UIR_MAX_AGENTS=20
