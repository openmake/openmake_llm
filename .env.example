# ============================================================
# OpenMake LLM — 환경 설정 Template
# ============================================================
# 이 파일은 .env 의 reference 입니다. 실제 운영용 .env 는 .gitignore 됩니다.
#
# 빠른 시작:
#   cp .env.example .env
#   # 아래 ⭐ 표시된 5개 변수는 반드시 실제 값으로 교체하세요.
#
# ============================================================
# ⭐ 필수 변수 (Required for first launch)
# ============================================================
#   1. DATABASE_URL          → 아래 "📊 인프라" 섹션
#   2. JWT_SECRET            → 아래 "🔐 서버 및 보안" 섹션
#   3. API_KEY_PEPPER        → 아래 "🔐 서버 및 보안" 섹션
#   4. ADMIN_PASSWORD        → 아래 "🔐 서버 및 보안" 섹션
#   5. LLM_BASE_URL          → 아래 "🤖 LLM Backend" 섹션 (LiteLLM proxy endpoint)
#
# 추가 권장 (production):
#   - TOKEN_ENCRYPTION_KEY   → OpenRouter 키 암호화 (미설정 시 평문 저장 경고)
#   - DEFAULT_ADMIN_EMAIL    → 관리자 로그인 email
#
# 64-hex 시크릿 생성:  openssl rand -hex 32

# *******************************************************
# 🤖 LLM Backend (vLLM via LiteLLM proxy)
# *******************************************************
# OpenMake LLM 백엔드는 OpenAI 호환 API 만 사용합니다.
# 운영 권장 토폴로지 (rockyhan 서버 실측 기준):
#   [OpenMake API] → [LiteLLM proxy :13401] → [vLLM 인스턴스
#       qwen3.6-35b-a3b :8002 (262K) / qwen3.6-35b-a3b-1m :8004 (1M) / bge-m3 :8003 (embedding)]
#
# 운영자 배포 가이드: docs/superpowers/plans/2026-05-20-vllm-server-setup.md
#
# 빠른 실행 (개발자 로컬, 운영자 환경 아닌 경우):
#   bash scripts/vllm/qwen-serve.sh      # :8002 (기본 채팅 262K)
#   bash scripts/vllm/qwen-1m-serve.sh   # :8004 (1M context, 선택적)
#   bash scripts/vllm/bge-m3-serve.sh    # :8003 (embedding)
#   litellm --config scripts/vllm/litellm.config.yaml --port 4000   # 로컬은 4000, 운영은 13401
#
# 운영자 배포 (systemd):
#   sudo cp scripts/vllm/*.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now openmake-vllm-qwen openmake-vllm-qwen-1m openmake-vllm-bge openmake-litellm

LLM_BASE_URL=http://localhost:4000              # 서버 PC 의 vLLM/LiteLLM proxy endpoint
                                                  # 운영 예: http://rockyhan.duckdns.org:13401
LLM_API_KEY=sk-litellm-master-key               # LiteLLM master key (또는 vLLM --api-key)
LLM_DEFAULT_MODEL=qwen3.6-35b-a3b               # proxy 가 라우팅하는 model 명 (chat 기본)
LLM_TIMEOUT=120000                              # HTTP 요청 타임아웃 (ms)

# ────────────────────────────────────────────────────────────
# 로컬 모델 카탈로그 (서버 PC 의 vLLM proxy 가 노출하는 모델 목록)
# ────────────────────────────────────────────────────────────
# 기본 카탈로그는 backend/api/src/config/local-models.ts 에 하드코드.
# 운영 환경에서 모델 추가/제거 시 본 환경변수로 override (JSON 배열):
#
#   LLM_LOCAL_MODELS_JSON='[
#     {"id":"qwen3.6-35b-a3b","displayName":"Qwen 3.6","description":"기본","role":"chat","contextLength":262144},
#     {"id":"qwen3.6-35b-a3b-1m","displayName":"Qwen 1M","description":"대용량","role":"chat","contextLength":1048576},
#     {"id":"gpt-3.5-turbo","displayName":"GPT-3.5 alias","description":"OpenAI 호환","role":"chat"},
#     {"id":"bge-m3","displayName":"BGE-M3","description":"Embedding","role":"embedding"}
#   ]'
#
# 새 모델 추가 절차 (클라이언트 PC 만 작업):
#   1. 서버 PC 의 vLLM 에 모델 띄움 + proxy 카탈로그 등록 (서버 PC 운영자 작업)
#   2. 본 환경변수 또는 config/local-models.ts 갱신
#   3. PM2 reload (또는 서비스 재시작) — selector dropdown 에 즉시 반영
#
# 모델 capability 매핑은 backend/api/src/config/model-defaults.ts 의
# MODEL_CAPABILITY_PRESETS prefix 매칭 (longest match). 새 model prefix 가 매칭 안 되면
# 보수적 default (toolCalling: true / thinking: false / vision: false / streaming: true).
# LLM_LOCAL_MODELS_JSON=
#
# 가용성 처리:
#   - startup probe (probeLocalModelAvailability) 가 proxy /v1/models 호출 + 모델 별
#     1-token chat ping 으로 실제 backend connectivity 검증
#   - runtime polling (startLocalModelProbeScheduler) 가 N분마다 재실행 — backend
#     장애 동적 감지 + 카탈로그 자동 갱신 + selector UI 반영
#   - 상태 전환 시 logger.warn ([LocalModelProbe] DOWN: ...) / info (UP)
#   - 선택적 모델 (예: qwen3.6-35b-a3b-1m / 서버 PC 8004 가동 시에만) 은 카탈로그에서
#     `available: false` 기본값 — 운영자가 8004 가동 후 활성화하려면:
#       1. config/local-models.ts 의 entry 에서 `available: false` 제거 후 PM2 reload
#       2. 또는 LLM_LOCAL_MODELS_JSON 으로 override (available: true 명시)
#
# Polling 인터벌 (default 5분 = 300000ms). 0 또는 음수 시 polling 비활성 (startup probe 만).
# LLM_MODEL_PROBE_INTERVAL_MS=300000

# Per-request fast-fail timeout (default 5000ms).
# - 첫 호출(retried=false) 에서 응답이 이 시간 내 미수신 시 즉시 reject → fallback 발동.
# - retry 호출(retried=true) 은 정상 LLM_TIMEOUT 사용 (fallback 의 cascade abort 방지).
# - 정상 모델 TTFT 는 보통 수백 ms — 5초면 thinking 모델도 안전. 0 또는 음수 시 비활성.
# LLM_FAST_FAIL_TIMEOUT_MS=5000

# Server boot 시 모델 워밍업 timeout (default 10000ms). PR #66.
# - LLM_TIMEOUT (chat 120s) 보다 짧음 — backend hang 으로 워밍업 무한 대기 방지.
# - 워밍업 실패해도 boot 는 정상 진행 (첫 사용자 요청 시 cold-load 발생 가능).
# LLM_WARMUP_TIMEOUT_MS=10000

# 토큰 기반 시간/주간 한도 (LLM 사용량 quota)
LLM_HOURLY_TOKEN_LIMIT=300000
LLM_WEEKLY_TOKEN_LIMIT=5000000

# Model Pool — 두 chat 모델 (262K / 1M) capacity 기반 proactive routing.
# 입력 + 예상 출력 합산이 default 모델 임계 초과 시 1M 으로 자동 전환.
# 답변 잘림 방지 (output 보호 우선 안전망).
# 자세한 정책: docs/superpowers/specs/2026-05-25-llm-model-pool-design.md
# LLM_POOL_ENABLED=true                            # false 시 routing 비활성 (rollback)
# LLM_POOL_DEFAULT_MODEL=qwen3.6-35b-a3b          # default (262K) model id
# LLM_POOL_LARGE_MODEL=qwen3.6-35b-a3b-1m         # large (1M) model id
# LLM_POOL_DEFAULT_CTX=262144                     # default 모델 nominal context
# LLM_POOL_LARGE_CTX=1048576                      # large 모델 nominal context
# LLM_POOL_DEFAULT_MARGIN_PCT=10                  # default 모델 safety margin %
# LLM_POOL_LARGE_MARGIN_PCT=5                     # large 모델 safety margin %
# LLM_POOL_ROUTING_MAX_TOKENS_DEFAULT=16384       # max_tokens 미지정 시 routing 계산용
# LLM_POOL_MIN_OUTPUT_TOKENS=4096                 # 1M 안전망 최소 출력 보장

# vLLM extra_body.reasoning_effort 전송 (opt-in, 기본 비활성).
# 모델/서버가 reasoning 지원 시에만 'true' 로 활성화 — vLLM 서버 가동 시
# `--reasoning-parser deepseek_r1|qwen3|granite|...` 옵션 함께 지정 필요.
LLM_ENABLE_REASONING_EFFORT=false

# 로컬(local-llm) 채팅을 strategy 계층(ThinkingStrategy/GV/AgentLoop/ExecutionPlanBuilder)
# 으로 라우팅할지 토글. false(기본)=현행 streamFromExternalProvider 직접 dispatch.
# true=strategy 경로 복귀 (2026-05-19 'ollama'→'local-llm' normalize 회귀 수정).
# 외부 provider(anthropic 등)는 이 값과 무관하게 항상 외부 dispatch.
LOCAL_STRATEGY_PATH_ENABLED=false

# Qwen3 등 reasoning 모델의 chat_template_kwargs.enable_thinking 자동 토글.
# 'true' 시: think 옵션 명시 없으면 enable_thinking=false 강제 → reasoning 토큰 차단.
# 'false' 시: 모델 chat_template 기본 동작 (reasoning 모델은 thinking 기본 ON 일 수 있음).
# GB10 하드웨어 (Grace Blackwell, 컴퓨트 한계) 권장: 'true' — TTFB 8.2s → 3.1s 단축.
LLM_DISABLE_THINKING_BY_DEFAULT=true

# *******************************************************
# 🌌 GEMINI 전용 상세 설정 (외부 BYO 키 — settings 페이지에서 등록)
# *******************************************************
GEMINI_THINK_ENABLED=true
GEMINI_THINK_LEVEL=high
GEMINI_NUM_CTX=32768
GEMINI_WEB_SEARCH_ENABLED=true

# *******************************************************
# 🔐 서버 및 보안 설정
# *******************************************************
PORT=52416
SERVER_HOST=localhost
NODE_ENV=development

# 인증 보안 키 — 64-hex 문자열, 생성: openssl rand -hex 32
JWT_SECRET=generate_with_openssl_rand_-hex_32                         # ⭐ 필수
API_KEY_PEPPER=generate_with_openssl_rand_-hex_32                     # ⭐ 필수 (production)
ADMIN_PASSWORD=your_secure_admin_password_here                        # ⭐ 필수 (8+ chars, 대문자/숫자/특수문자 포함)

# OAuth 토큰 암호화 키 (P0 보안 - 프로덕션 필수!)
# external_connections / user_external_api_keys 테이블의 토큰·API 키를 AES-256-GCM으로 암호화합니다.
# (외부 LLM provider BYO Key — Anthropic, OpenAI 호환 — 도 동일 키 재사용)
# 반드시 64자리 hex 문자열(32 bytes)이어야 합니다.
# 생성 방법: openssl rand -hex 32
# 미설정 시: 토큰이 평문으로 저장됩니다 (개발환경 허용, 프로덕션 금지)
# 경고: 키를 변경하면 기존 암호화된 토큰을 복호화할 수 없습니다. 키는 안전하게 보관하세요.
TOKEN_ENCRYPTION_KEY=

# *******************************************************
# 🌐 외부 LLM PROVIDER (OpenRouter 단독, post-2026-05-08 migration 018)
# *******************************************************
# 외부 LLM 카탈로그가 OpenRouter 단일 provider 로 축소됨 (migration 018).
# OpenRouter 단일 키 → 367+ 모델 (GPT-5, Claude, Gemini, Llama, DeepSeek 등) 라우팅.
# 사용자별 BYO Key — 운영자가 키를 설정하지 않습니다.
# 등록 위치: Settings 페이지 → AI 모델 → 기본 모델 → ModelSelector → "+ OpenRouter 키 등록".
# 키는 AES-256-GCM 으로 user_external_api_keys 테이블에 암호화 저장 (TOKEN_ENCRYPTION_KEY 사용).

# OpenRouter /v1/models 응답 캐시 TTL (ms, 기본 1시간) — listOpenRouterModels 가 사용
EXTERNAL_MODELS_CACHE_TTL_MS=3600000

# 외부 provider 사용량 통계 보존 기간 (일, 기본 90일)
# db-retention 스케줄러가 cron 으로 자동 정리 (services/db-retention.ts)
EXTERNAL_USAGE_RETENTION_DAYS=90

# GDPR Phase C Fix 9 — consent_logs PII (IP/User-Agent) 익명화 기간 (일, 기본 90일).
# granted_at 기준 N일 후 ip_address/user_agent 를 NULL 로 UPDATE (row 보존, PII 만 제거).
# Article 5(1)(c) data minimization + 7(1) demonstrability 동시 충족.
# 0 또는 음수 시 비활성 (legacy/test 환경).
# CONSENT_PII_RETENTION_DAYS=90

# audit_logs PII 익명화 기간 (일, 기본 90일).
# timestamp 기준 N일 후 ip_address/user_agent NULL + details.actor (email/role) 제거.
# action/user_id/resource_* 는 보존 (Article 30 record of processing).
# AUDIT_PII_RETENTION_DAYS=90

# alert_history PII 익명화 기간 (일, 기본 90일).
# created_at 기준 N일 후 data.actor/ipAddress/userAgent 제거 (JSONB minus).
# type/severity/title/message/data.userId 는 보존.
# ALERT_PII_RETENTION_DAYS=90

# audit_logs CSV export 최대 row 수 (admin 전용 GET /api/audit/export).
# 무거운 query 방어 — 큰 export 는 paged 호출로 분할 권장.
# AUDIT_CSV_MAX_ROWS=10000

# alert_history CSV export 최대 row 수 (admin 전용 GET /api/admin/alerts/export).
# 동일 방어 정책. 알림 이력은 audit_logs 보다 빈도 낮아 default 충분.
# ALERT_CSV_MAX_ROWS=10000

# GDPR Phase D — 운영자 알림 (14세 미만 가입 대기 시 즉시 알림).
# Slack/Discord incoming webhook URL. 설정 시 AlertSystem (monitoring/alerts.ts) 가
# webhook 채널 자동 활성. type=minor_pending_registered 알림이 본 URL 에 POST 됨.
# 미설정 시 console 채널만 (PM2 logs 에서 확인).
# OPERATOR_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Severity 별 webhook URL 분리 (옵션). 명시 설정 시 OPERATOR_WEBHOOK_URL 보다 우선.
# 운영팀이 noise 분리를 원할 때 사용:
#   - critical: user_deleted/role_changed 등 즉시 통보 → 전담 채널 (예: #alerts-critical)
#   - warning : consent_withdrawn/export_requested 등 → #alerts-warning
#   - info    : register/login_failed/consent_granted 등 → 기본 미발송 (명시 시만 발송)
# critical/warning 미설정 시 OPERATOR_WEBHOOK_URL 로 fallback. info 는 명시 안 하면 console 만.
# OPERATOR_WEBHOOK_URL_CRITICAL=https://hooks.slack.com/services/XXX/YYY/AAA
# OPERATOR_WEBHOOK_URL_WARNING=https://hooks.slack.com/services/XXX/YYY/BBB
# OPERATOR_WEBHOOK_URL_INFO=https://hooks.slack.com/services/XXX/YYY/CCC

# Severity 별 알림 쿨다운 (분). 동일 type+severity 키의 중복 알림 spam 방지.
# - info: 60분 default — 빈도 높은 register/login_failed/consent_granted spam 회피
# - warning: 15분 default — 일반 critical event
# - critical: 1분 default — user_deleted/role_changed 등 즉시 통보
# console 채널은 cooldown 영향 받음 (webhook 만 spam 방어가 아님)
# ALERT_COOLDOWN_INFO_MIN=60
# ALERT_COOLDOWN_WARNING_MIN=15
# ALERT_COOLDOWN_CRITICAL_MIN=1

# OpenRouter API 호출 타임아웃 (ms, 기본 2분)
EXTERNAL_PROVIDER_REQUEST_TIMEOUT_MS=120000

# 외부 키 검증(/validate) Rate Limit (분당 요청 수, 기본 30)
OMK_EXTERNAL_KEY_VALIDATION_RATE_LIMIT=30

# /api/api-keys GET 요청 한도 (15분 window, 기본 200)
# settings 페이지 진입마다 호출되므로 mutation 한도(POST/DELETE 10)와 분리.
# 5분 sessionStorage 캐시가 frontend 에 적용되어 있어 일반 사용 시 한도 초과 없음.
RL_API_KEY_MGMT_READ=200

# 관리자 권한 설정
ADMIN_EMAILS=admin@example.com
DEFAULT_ADMIN_EMAIL=admin@example.com

# *******************************************************
# 🔑 GOOGLE OAUTH 2.0 (소셜 로그인)
# *******************************************************
# Google Cloud Console에서 OAuth 2.0 자격증명 생성
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:52416/api/auth/callback/google

# *******************************************************
# 🔍 웹 검색 설정 (Google Custom Search)
# *******************************************************
# Google API 키 (Google Custom Search 활성화 필요)
GOOGLE_API_KEY=your_google_api_key_here
# Google Custom Search Engine ID
GOOGLE_CSE_ID=your_google_cse_id_here

# *******************************************************
# 📊 인프라 및 네트워크 설정
# *******************************************************
# PostgreSQL 데이터베이스 — 운영 전 db + user + password 생성 필요
# Setup: psql postgres -c "CREATE USER openmake WITH PASSWORD '<pw>'; CREATE DATABASE openmake_llm OWNER openmake;"
# 스키마는 첫 실행 시 자동 생성 (services/database/init/002-schema.sql)
# 마이그레이션 적용 (필요 시): npx ts-node backend/api/src/data/migrations/cli.ts migrate
DATABASE_URL=postgresql://openmake:your_password@localhost:5432/openmake_llm  # ⭐ 필수

# 캐시 설정
CACHE_MAX_SIZE=1000
CACHE_TTL=1800000

# CORS 및 API 문서 (프로덕션에서는 실제 도메인으로 변경)
CORS_ORIGINS=http://localhost:52416,http://localhost:5173,http://localhost:3000
SWAGGER_BASE_URL=http://localhost:52416
LOG_LEVEL=info

# Rate Limiting (900초당 100회 제한)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# *******************************************************
# 💰 비용 티어 (선택)
# *******************************************************
# 사용자 기본 비용 티어 — economy / standard / premium
#   premium  = 제한 없음 (기본값)
#   standard = 중간 한도
#   economy  = 최저 비용 (제한적 모델 접근)
OMK_COST_TIER_DEFAULT=premium

# 도메인별 전문 모델 (선택, 빈 값 = LLM_DEFAULT_MODEL 사용)
# Auto-routing 시 LLM classifier 가 도메인 분류 후 매핑된 모델로 위임 (LiteLLM alias).
# 미설정 시 기본 chat 모델로 통합 응답 — 도메인 분리 비활성.
# OMK_DOMAIN_CODE=qwen-coder
# OMK_DOMAIN_MATH=qwen2.5-72b
# OMK_DOMAIN_CREATIVE=qwen2.5-72b
# OMK_DOMAIN_ANALYSIS=qwen2.5-72b
# OMK_DOMAIN_GENERAL=qwen2.5-7b

# Cookie Security (HTTPS 없이 운영 시 false, HTTPS 환경에서는 true 권장)
COOKIE_SECURE=false

# HTTPS 미지원 production 환경에서 COOKIE_SECURE=false 를 명시적으로 허용 (opt-out).
# 기본 false — 실수로 평문 쿠키 전송되는 것을 부트타임에 차단하는 안전망.
# true 설정 시 JWT 쿠키가 평문 HTTP 로 전송되어 MITM 탈취에 노출됨 → 내부망/로컬 전용으로만 사용.
# ALLOW_INSECURE_COOKIES=false

# *******************************************************
# 🛡️ 보안 정책 (Stage 1-2 additive 설정, 기본값 = 기존 동작 유지)
# *******************************************************
# JWT 블랙리스트 DB 장애 시 동작:
#   open (기본) = 통과 (가용성 우선, 기존 동작)
#   safe        = 거부 (탈취 토큰 재사용 창 봉쇄, 보안 우선)
# BLACKLIST_FAIL_MODE=open

# CSRF Double-Submit Cookie 정책:
#   off     = 검증 비활성
#   warn    = 불일치 로깅만, 요청 통과 (기본, 롤아웃 모니터링용)
#   enforce = 불일치 시 403 반환
# CSRF_PROTECTION=warn

# Shared Storage 백엔드 (rate limiter, OAuth state):
#   memory = per-instance in-memory (기본, 단일 인스턴스 배포)
#   redis  = 공용 스토리지 (멀티 인스턴스 필수, REDIS_URL 요구)
# STORAGE_BACKEND=memory
# REDIS_URL=redis://localhost:6379

# *******************************************************
# 🌐 웹 스크래핑 (무료, API 키 불필요)
# *******************************************************
# web_scrape, web_map, web_crawl MCP 도구가 항상 활성화됩니다.
# Readability + Turndown 기반, SPA 사이트는 Playwright fallback 사용.
# Playwright fallback을 위해: npx playwright install chromium
# *******************************************************
# 🌐 다국어 응답 정책 (Language Policy)
# *******************************************************
# 동적 언어 감지 활성화 (false=기본 언어로 고정, true=사용자 언어 자동 감지)
ENABLE_DYNAMIC_RESPONSE_LANGUAGE=false
# 기본 응답 언어 (ko, en, ja, zh, es, fr, de 등 20개 지원)
DEFAULT_RESPONSE_LANGUAGE=ko
# 언어 감지 최소 신뢰도 (0.0~1.0, 미만 시 fallback 언어 사용)
LANGUAGE_DETECTION_MIN_CONFIDENCE=0.7
# 감지 실패 시 폴백 언어
LANGUAGE_FALLBACK_LANGUAGE=en

# *******************************************************
# LLM 라우팅 설정 (선택적, 기본값 사용 권장)
# *******************************************************
# 쿼리 분류 모델 (기본값: LLM_DEFAULT_MODEL → ROLE_DEFAULTS, 단일 로컬 모델 환경)
# 별도 모델로 분리하려면 명시 — model-roles 레지스트리가 자동 위임
# OMK_CLASSIFIER_MODEL=gemma4:e4b

# LLM classifier 우회 (단일 모델 환경 latency 최적화):
#   true  → 항상 우회. selectOptimalModel()이 regex/fast-path 만으로 QueryType 결정.
#   false → 항상 활성. 다중 모델 환경에서 분류 정밀도 우선.
#   미설정/'auto' → 단일 모델 환경 자동 감지 (MODEL_PRESETS 키 1개 이하면 우회).
# 분류 결과는 옵션 튜닝(temperature/top_p) 에만 영향 — 단일 모델에서는 모델 선택에 영향 없음.
# OMK_DISABLE_LLM_CLASSIFIER=auto

# LLM 분류 최소 신뢰도 임계값 (기본값: 0.7, 이 값 미만이면 regex fallback)
# OMK_CONFIDENCE_THRESHOLD=0.7

# LLM 분류기 temperature - 낮을수록 결정적 응답 (기본값: 0.1)
# OMK_CLASSIFIER_TEMPERATURE=0.1

# LLM 분류기 컨텍스트 토큰 수 (기본값: 1024)
# OMK_CLASSIFIER_NUM_CTX=1024

# LLM 라우터 temperature - 낮을수록 결정적 응답 (기본값: 0.1)
# OMK_ROUTER_TEMPERATURE=0.1

# LLM 라우터 최대 예측 토큰 수 (기본값: 200)
# OMK_ROUTER_NUM_PREDICT=200

# A2A 건너뛰기 임계값 - 이 점수 미만이면 A2A 단계 생략 (기본값: 0.3)
# OMK_A2A_SKIP_THRESHOLD=0.3

# 카테고리 직접 매칭 부스트 점수 (기본값: 3)
# OMK_CATEGORY_BOOST=3

# 확장 키워드 감쇠 계수 (기본값: 0.3)
# OMK_EXPANDED_DAMPING=0.3

# *******************************************************
# 모델 역할 레지스트리 (model-roles.ts) — 단일 로컬 모델 환경
# *******************************************************
# OMK_CHAT_MODEL / OMK_CLASSIFIER_MODEL / OMK_ROUTER_MODEL 로 역할별 모델 override.
# OMK_EMBEDDING_MODEL: 2026-05-19 제거 (vector cache / semantic router 폐기)

# *******************************************************
# Thinking / 토큰 예산 (chat/request-handler, services/ChatService)
# *******************************************************
# Thinking 모드 활성화 시 num_predict 최소 보장 (기본값: 4096)
# Ollama 응답에서 message.thinking 과 message.content 가 같은 토큰 풀을 공유하므로
# 작은 cap(예: 512)에서 thinking 모델이 사고에 토큰을 다 쓰면 응답이 비어 나옴.
# OMK_THINKING_MIN_TOKENS=4096

# ThinkingStrategy 스트리밍/추출 한도 (config/runtime-limits THINKING_LIMITS)
# 스트리밍 버퍼 overflow 임계 / trim 길이 (문자, 기본 200 / 50)
# THINKING_BUFFER_OVERFLOW_CHARS=200
# THINKING_BUFFER_TRIM_CHARS=50
# 결론·추론 섹션 추출 최대 길이 (문자, 기본 500 / 1500)
# THINKING_CONCLUSION_MAX_CHARS=500
# THINKING_REASONING_MAX_CHARS=1500

# *******************************************************
# LLM HTTP 재시도 정책 (OpenAI SDK 자체 retry 와 별개의 추가 안전망)
# *******************************************************
# 최대 재시도 횟수 — 4xx/5xx (기본값: 3)
# OMK_LLM_MAX_FALLBACK_ATTEMPTS=3

# 네트워크 에러(ETIMEDOUT 등) 최대 재시도 횟수 (기본값: 2)
# OMK_LLM_MAX_NETWORK_RETRIES=2

# 지수 백오프 base 지연 (ms) — backoffMs = base * 2^retryCount (기본값: 1000)
# OMK_LLM_NETWORK_BACKOFF_BASE_MS=1000

# *******************************************************
# 프롬프트 캐시 (chat/prompt-templates PromptCache)
# *******************************************************
# TTL (ms, 기본값: 5분)
# OMK_PROMPT_CACHE_TTL_MS=300000

# 최대 엔트리 수 (기본값: 50)
# OMK_PROMPT_CACHE_MAX_SIZE=50

# *******************************************************
# 히스토리 요약 캐시 (services/chat-service/history-summary-cache, CACHE_CONFIG)
# *******************************************************
# 최대 엔트리 수 (기본값: 500)
# HISTORY_SUMMARY_MAX_ENTRIES=500
# TTL (ms, 기본값: 30분 = 1800000)
# HISTORY_SUMMARY_TTL_MS=1800000

# *******************************************************
# Discussion / Deep Research 런타임 한도 (config/runtime-limits)
# *******************************************************
# Discussion 이미지 설명 생성 최대 토큰 (기본 500)
# DISCUSSION_MAX_IMAGE_DESC_TOKENS=500
# Discussion 결과 스트리밍 abort 체크 간격 (문자 N개마다, 기본 100)
# DISCUSSION_ABORT_CHECK_INTERVAL=100
# Deep Research 스크랩 abort 안전마진 (ms, 기본 1000)
# SCRAPE_ABORT_BUFFER_MS=1000

# *******************************************************
# OAuth state (CSRF 방어) — controllers/auth-oauth.controller
# *******************************************************
# state 만료 (ms, 기본 5분=300000)
# OAUTH_STATE_TTL_MS=300000
# state 정리 주기 (ms, 기본 60초=60000)
# OAUTH_STATE_CLEANUP_INTERVAL_MS=60000

# *******************************************************
# 채팅 일일 한도 / rate limit 캐시 — middlewares/chat-rate-limiter
# *******************************************************
# 등급/역할별 일일 채팅 한도 (admin·enterprise 는 무제한 고정)
# CHAT_DAILY_LIMIT_PRO=1000
# CHAT_DAILY_LIMIT_FREE=100
# CHAT_DAILY_LIMIT_USER=100
# CHAT_DAILY_LIMIT_GUEST=20
# rate limit 인메모리 캐시 최대 항목 수 (기본 10000)
# CHAT_RATE_LIMIT_CACHE_MAX=10000

# *******************************************************
# Semantic Compactor (services/semantic-compactor)
# *******************************************************
# 도구 결과 요약 시 결정론적 응답 강제 temperature (기본값: 0)
# LLM_TEMP_SEMANTIC_COMPACTION=0

# *******************************************************
# 디버그 큐 TTL (data/conversation-debug-queue, B+ Phase B4/B5)
# *******************************************************
# 에러 자동 보존 TTL (ms, 기본값: 24시간 = 86400000)
# OMK_DEBUG_QUEUE_AUTO_ERROR_TTL_MS=86400000

# 사용자 신고 보존 TTL (ms, 기본값: 7일 = 604800000)
# OMK_DEBUG_QUEUE_USER_REPORT_TTL_MS=604800000

# ── OpenRouter attribution headers (선택) ─────────────────────────────
# OpenRouter rankings (https://openrouter.ai/rankings) 에 본 앱이 노출되도록
# OpenAICompatProvider constructor (openai-compat-provider.ts:280-313) 가
# defaultHeaders 로 첨부:
#   - OMK_APP_URL        → HTTP-Referer
#   - OMK_APP_TITLE      → X-OpenRouter-Title
#   - OMK_APP_CATEGORIES → X-OpenRouter-Categories
# 미설정 시 헤더 없이 호출 — 기능 동작에는 영향 없음.
OMK_APP_URL=https://your-domain.example.com
OMK_APP_TITLE=OpenMake LLM
OMK_APP_CATEGORIES=ai-platform

# ── 보안 헤더 (선택) ──────────────────────────────────────────────────
# Cross-Origin-Opener-Policy 활성화. HTTPS origin 에서만 의미 있음 — HTTP/IP
# 환경에서는 브라우저가 헤더를 무시하며 매 요청마다 경고 로그 발생.
# Caddy/Cloudflare Tunnel 등으로 HTTPS 도입 후 true 로 설정.
OMK_COOP_ENABLED=false


# ── Skill Creator (Phase 1) ───────────────────────────────────────────
# 자연어 prompt 로 LLM 이 SKILL 매니페스트를 작성해 draft 로 저장하는 기능.
# REST: POST /api/agents/skills/auto-create
# MCP tool: create_skill
# 검토 UX: 채팅 inline 카드 + 스킬 라이브러리 "AI 자동 생성" 탭

# 전체 기능 ON/OFF. false 면 /auto-create 가 503 + FEATURE_DISABLED 응답.
SKILL_CREATOR_ENABLED=true

# false 면 admin 만 호출 가능 (일반 user 는 503 + FEATURE_ADMIN_ONLY).
SKILL_CREATOR_USER_TIER_ENABLED=true

# LLM 호출 시 사용할 모델. 비어있으면 사용자의 채팅 fallback 모델 사용 (modelTier='user-fallback').
# 예: qwen3.6-35b-a3b, claude-haiku-4-5-20251001
SKILL_AUTHOR_MODEL=

# system 모델이 schema 검증을 두 번 실패하면 user fallback 모델로 재시도할지.
# true=재시도 / false=즉시 LLM_PARSE_FAIL 반환.
SKILL_AUTHOR_FALLBACK=true

# draft 상태로 보존하는 기간 (일). 이후 정리 스크립트가 archived 로 전환.
SKILL_DRAFT_TTL_DAYS=30

# 사용자 1인당 누적 draft 상한. 초과 시 DRAFT_LIMIT_EXCEEDED.
SKILL_AUTO_CREATE_MAX_DRAFTS_PER_USER=50

# E2E 테스트 전용 — true 면 LLM 호출 우회하고 결정론적 mock 매니페스트 반환.
# 운영 환경에서는 절대 true 설정 금지 (보안 + 데이터 무결성).
# CI 의 playwright 또는 jest e2e 테스트에서만 사용:
#   SKILL_AUTHOR_MOCK=true PORT=52417 npm run dev:api
SKILL_AUTHOR_MOCK=false

# Git URL ingest (Phase 2) — POST /api/agents/skills/import-from-git
# Git URL 에서 SKILL.md 매니페스트를 fetch → validate → draft 저장.
SKILL_CREATOR_GIT_INGEST_ENABLED=true
SKILL_CREATOR_GIT_FETCH_TIMEOUT_MS=30000
SKILL_CREATOR_GIT_MAX_FILE_SIZE=262144
SKILL_CREATOR_GIT_MAX_FILES_PER_REPO=50

# Agent Creator (Phase 3) — Git URL → AGENT.md → draft 워크플로
# POST /api/agents/custom/import-from-git
AGENT_CREATOR_ENABLED=true
AGENT_CREATOR_USER_TIER_ENABLED=true
AGENT_CREATOR_GIT_INGEST_ENABLED=true
AGENT_CREATOR_MAX_DRAFTS_PER_USER=20

# ============================================================
# Phase 4: MCP server manifest Git ingest
# POST /api/mcp/servers/import-from-git → MCPSERVER.md → draft INSERT
# ============================================================
# 기본 활성. false 면 import 엔드포인트가 503 MCP_INGEST_DISABLED 반환.
MCP_INGEST_ENABLED=true
# 사용자별 draft 상한 (rate limit 과 별개 — 누적된 draft 보유 한도)
MCP_INGEST_MAX_DRAFTS_PER_USER=20
# 동일 (uid+url+sha+path) hash dedupe 윈도우. 이 시간 안 재호출은 같은 draft 반환.
MCP_INGEST_DEDUPE_HOURS=24
# Git fetch HTTP timeout
MCP_INGEST_FETCH_TIMEOUT_MS=15000
# MCPSERVER.md 최대 크기 (256KB)
MCP_INGEST_MAX_FILE_SIZE_BYTES=262144
# admin 의 target=global 등록 허용 (별도 경로, 기본 옵션)
MCP_INGEST_ADMIN_GLOBAL=true

# Rate limit (시간당 N건, tier 별 차등). 0 또는 미지정 시 코드 기본값 사용.
RL_MCP_INGEST_FREE=5
RL_MCP_INGEST_PRO=15
RL_MCP_INGEST_ENTERPRISE=50
RL_MCP_INGEST_ADMIN=50
