{
  "root": true,
  "env": {
    "es2022": true,
    "node": true
  },
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "no-undef": "off",
    "@typescript-eslint/no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "max-lines": ["warn", {
      "max": 400,
      "skipBlankLines": true,
      "skipComments": true
    }]
  },
  "overrides": [
    {
      "files": ["frontend/web/public/**/*.js"],
      "env": {
        "browser": true,
        "node": false
      },
      "parserOptions": {
        "sourceType": "module"
      },
      "rules": {
        "no-undef": "off"
      }
    }
  ]
}
